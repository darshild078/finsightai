# ═══════════════════════════════════════════════════════════════════════════════
# FinSight AI - Complete Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# 
# Copy this file to .env and fill in the values according to your setup.
# For new users: follow the instructions and examples in each section below.
#
# SECTIONS:
#   1. FRONTEND CONFIGURATION
#   2. BACKEND CORE SETTINGS
#   3. RETRIEVAL & SEARCH PIPELINE
#   4. GENERATION & LLM
#   5. DATABASE & STORAGE
#   6. AUTHENTICATION
#   7. OPTIMIZATION & PERFORMANCE
#   8. MONITORING & LOGGING
# ═══════════════════════════════════════════════════════════════════════════════


# ───────────────────────────────────────────────────────────────────────────────
# 1. FRONTEND CONFIGURATION (React + Vite)
# ───────────────────────────────────────────────────────────────────────────────

# Backend API base URL
# Development: http://localhost:8000
# Production: https://your-production-backend.com
VITE_API_BASE=http://localhost:8000


# ───────────────────────────────────────────────────────────────────────────────
# 2. BACKEND CORE SETTINGS
# ───────────────────────────────────────────────────────────────────────────────

# Path to your PDF file (relative to backend/ folder)
# Example: data/sample.pdf, data/annual_reports/TCS_2024.pdf
PDF_PATH=data/sample.pdf

# Index persistence directory
# Where FAISS indexes and metadata are stored
INDEX_CACHE_DIR=index_cache


# ───────────────────────────────────────────────────────────────────────────────
# 3. RETRIEVAL & SEARCH PIPELINE
# ───────────────────────────────────────────────────────────────────────────────

# Embedding Model (Phase 1: Core Retrieval)
# BAAI/bge-base-en-v1.5: 768-dim, instruction-based asymmetric retrieval (recommended)
# Alternatives: 
#   - bge-large-en-v1.5 (1024-dim, better quality but slower)
#   - all-MiniLM-L6-v2 (384-dim, lightweight)
#   - e5-base-v2 (768-dim, generic multilingual)
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5

# Chunk settings (optimized for financial table coherence)
# CHUNK_SIZE: larger chunks preserve context better for tables
# CHUNK_OVERLAP: % overlap prevents sentence boundary loss
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Retrieval settings (Phase 2: Multi-level retrieval)
# RETRIEVAL_K: number of candidates to retrieve before reranking
# FINAL_K: number of results to return to the LLM
# TOP_K: default number of results for API responses
RETRIEVAL_K=10
FINAL_K=5
TOP_K=5

# Similarity score threshold (cosine similarity, 0-1)
# Chunks below this score are filtered out before reaching the LLM
# Start conservative at 0.30; tune upward after analyzing score distributions
SIMILARITY_THRESHOLD=0.30

# Query instruction prefix for BGE asymmetric retrieval
# Applied to queries only, NOT to document chunks during indexing
QUERY_INSTRUCTION=Represent this sentence for searching relevant passages:

# Cross-encoder reranking (Phase 2: Quality improvement)
# RERANKER_ENABLED: true to use reranking, false to skip
# RERANKER_MODEL: model for ranking candidate results
RERANKER_ENABLED=true
RERANKER_MODEL=BAAI/bge-reranker-base

# Metadata boost weights (applied after reranking)
# Increases scores for results matching company/year/document type
BOOST_COMPANY=0.08
BOOST_YEAR=0.04
BOOST_DOCTYPE=0.03

# Deduplication & diversity (Phase 2: Avoid redundancy)
# DEDUP_THRESHOLD: similarity threshold for considering chunks as duplicates
# MAX_FROM_ONE_DOC: max proportion of results from a single document
DEDUP_THRESHOLD=0.85
MAX_FROM_ONE_DOC=0.6

# Context enrichment (Phase 2: Local context)
# 0=disabled, 1=merge ±1 neighbors for fuller context
CONTEXT_WINDOW=0

# Default document metadata
# Used when no metadata is extracted from the document
DEFAULT_COMPANY=demo_company
DEFAULT_DOC_TYPE=DRHP
DEFAULT_YEAR=2024

# Multi-query retrieval (Phase 3: Query expansion via LLM)
# DISABLED by default (saves ~2-3s per request)
MULTI_QUERY_ENABLED=false
MULTI_QUERY_COUNT=3

# Hybrid search (Phase 3: Combine dense + sparse retrieval)
# BM25: term-frequency-based sparse search
BM25_ENABLED=true
BM25_WEIGHT=0.3

# Query expansion via LLM (Phase 3: Synonym generation)
QUERY_EXPANSION_LLM=false

# Result merging (Phase 3: Reciprocal Rank Fusion)
RRF_K=60
MAX_DOC_CONCENTRATION=0.4

# Intelligent query understanding (Phase 4: LLM-based parsing)
# DISABLED by default (saves ~2-3s per request)
INTELLIGENT_PARSING_ENABLED=false
MAX_RETRIEVAL_STEPS=4
MULTI_STEP_RETRIEVAL_K=10


# ───────────────────────────────────────────────────────────────────────────────
# 4. GENERATION & LLM (Phase 2: RAG Answer Generation)
# ───────────────────────────────────────────────────────────────────────────────

# OpenAI API Configuration
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini


# ───────────────────────────────────────────────────────────────────────────────
# 5. DATABASE & STORAGE
# ───────────────────────────────────────────────────────────────────────────────

# MongoDB Configuration
# MONGO_URI examples:
#   Local: mongodb://localhost:27017
#   Atlas: mongodb+srv://username:password@cluster.mongodb.net/database?appName=AppName
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=finsightai


# ───────────────────────────────────────────────────────────────────────────────
# 6. AUTHENTICATION
# ───────────────────────────────────────────────────────────────────────────────

# JWT Secret (for authentication tokens)
# ⚠️  CHANGE THIS TO A STRONG RANDOM STRING IN PRODUCTION
# Generate one: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=change-me-to-a-strong-random-secret

# Google OAuth 2.0 (optional, for social login)
# Get your credentials from: https://console.cloud.google.com
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# OAuth Redirect URI (must match Google Cloud Console)
# Development: http://localhost:8000/auth/callback
# Production: https://your-domain.com/auth/callback
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# Frontend URL (for CORS and redirects)
# Development: http://localhost:5173
# Production: https://your-domain.com
FRONTEND_URL=http://localhost:5173


# ───────────────────────────────────────────────────────────────────────────────
# 7. OPTIMIZATION & PERFORMANCE (Phase 6: Caching & Speed)
# ───────────────────────────────────────────────────────────────────────────────

# Response caching
CACHE_ENABLED=true
CACHE_MAX_SIZE=500
CACHE_TTL_SECONDS=3600

# Reranking optimization
RERANKER_MAX_CANDIDATES=5
SKIP_RERANKER_THRESHOLD=0.85


# ───────────────────────────────────────────────────────────────────────────────
# 8. MONITORING & LOGGING (Phase 7: Observability)
# ───────────────────────────────────────────────────────────────────────────────

# Query logging for monitoring and analytics
QUERY_LOG_ENABLED=true
