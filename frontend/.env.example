# ═══════════════════════════════════════════════════════════════════════════════
# FinSight AI Frontend - Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
#
# Copy this file to .env.development (for local development) or .env.production
# (for production builds) and fill in the values according to your setup.
#
# ═══════════════════════════════════════════════════════════════════════════════


# Backend API Base URL
# This is where the React frontend sends requests to
#
# DEVELOPMENT:
#   http://localhost:8000        (if backend runs locally on port 8000)
#
# PRODUCTION:
#   https://api.finsightai.com  (your production backend domain)
#   https://backend.yourdomain.com
#
# ⚠️  Make sure this matches your backend server URL exactly
VITE_API_BASE=http://localhost:8000
